<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ONE Fit</title>
  <meta name="description" content="ONE Fit is het alles-in-één fitness- en calisthenicsplatform met workouts, voedingsschema's, progress tracking en trainingsadvies." />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="header">
    <div class="logo">ONE <span>Fit</span></div>
    <nav class="nav">
      <a href="#home">Home</a>
      <a href="#workouts">Workouts</a>
      <a href="#voeding">Voeding</a>
      <a href="#progress">Progress</a>
      <a href="#contact">Contact</a>
    </nav>
    <button class="menu-btn" onclick="toggleMenu()">☰</button>
  </header>

  <nav id="mobileMenu" class="mobile-menu">
    <a href="#home" onclick="closeMenu()">Home</a>
    <a href="#workouts" onclick="closeMenu()">Workouts</a>
    <a href="#voeding" onclick="closeMenu()">Voeding</a>
    <a href="#progress" onclick="closeMenu()">Progress</a>
    <a href="#contact" onclick="closeMenu()">Contact</a>
  </nav>

  <section id="home" class="hero">
    <div class="hero-content">
      <h1>Word sterker met ONE Fit</h1>
      <p>Het alles-in-één platform voor fitness, calisthenics, voeding en progressie.</p>
      <a href="#workouts" class="btn">Start Nu</a>
    </div>
  </section>

  <section class="stats">
    <div class="stat-card">
      <h2>100+</h2>
      <p>Oefeningen</p>
    </div>
    <div class="stat-card">
      <h2>30</h2>
      <p>Trainingsschema's</p>
    </div>
    <div class="stat-card">
      <h2>24/7</h2>
      <p>Toegang</p>
    </div>
  </section>

  <section id="workouts" class="section">
    <h2>Workouts</h2>
    <div class="grid">
      <div class="card">
        <h3>Upper Body</h3>
        <p>Push-ups, pull-ups, dips en meer.</p>
      </div>
      <div class="card">
        <h3>Lower Body</h3>
        <p>Squats, lunges, jumps en core strength.</p>
      </div>
      <div class="card">
        <h3>Full Body</h3>
        <p>Complete sessies voor kracht en conditie.</p>
      </div>
    </div>
  </section>

  <section id="voeding" class="section alt">
    <h2>Voeding</h2>
    <div class="grid">
      <div class="card">
        <h3>Bulk</h3>
        <p>Meer calorieën voor spiergroei.</p>
      </div>
      <div class="card">
        <h3>Cut</h3>
        <p>Vet verliezen zonder kracht te verliezen.</p>
      </div>
      <div class="card">
        <h3>Onderhoud</h3>
        <p>Balans tussen energie en herstel.</p>
      </div>
    </div>
  </section>

  <section id="progress" class="section">
    <h2>Progress Tracker</h2>
    <div class="tracker">
      <label for="weight">Gewicht (kg)</label>
      <input type="number" id="weight" placeholder="Bijv. 75" />

      <label for="goal">Doel</label>
      <select id="goal">
        <option value="bulk">Bulk</option>
        <option value="cut">Cut</option>
        <option value="maintenance">Onderhoud</option>
      </select>

      <button class="btn" onclick="calculatePlan()">Bereken plan</button>
      <p id="result"></p>
    </div>
  </section>

  <section id="contact" class="section alt">
    <h2>Contact</h2>
    <p>Stuur een bericht via je toekomstige contactformulier of e-mail.</p>
  </section>

  <footer class="footer">
    <p>© 2026 ONE Fit. Alle rechten voorbehouden.</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: Arial, Helvetica, sans-serif;
  background: #0f1115;
  color: #ffffff;
  line-height: 1.6;
}

.header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(15, 17, 21, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 6%;
  border-bottom: 1px solid #222;
}

.logo {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: 1px;
}

.logo span {
  color: #00e676;
}

.nav {
  display: flex;
  gap: 24px;
}

.nav a,
.mobile-menu a {
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  transition: 0.3s;
}

.nav a:hover,
.mobile-menu a:hover {
  color: #00e676;
}

.menu-btn {
  display: none;
  background: none;
  border: none;
  color: #fff;
  font-size: 1.8rem;
  cursor: pointer;
}

.mobile-menu {
  display: none;
  flex-direction: column;
  background: #151922;
  padding: 20px 6%;
  gap: 14px;
  border-bottom: 1px solid #222;
}

.hero {
  min-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 20px;
  background: linear-gradient(rgba(15,17,21,0.75), rgba(15,17,21,0.75)),
    url('https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
}

.hero-content {
  max-width: 800px;
}

.hero h1 {
  font-size: clamp(2.4rem, 6vw, 5rem);
  margin-bottom: 18px;
}

.hero p {
  font-size: 1.2rem;
  color: #d5d5d5;
  margin-bottom: 30px;
}

.btn {
  display: inline-block;
  padding: 14px 28px;
  background: #00e676;
  color: #08110b;
  text-decoration: none;
  font-weight: 800;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  transition: 0.3s;
}

.btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0, 230, 118, 0.25);
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  padding: 30px 6%;
  margin-top: -40px;
}

.stat-card {
  background: #171b23;
  border: 1px solid #262b36;
  padding: 28px;
  text-align: center;
  border-radius: 18px;
}

.stat-card h2 {
  font-size: 2rem;
  color: #00e676;
  margin-bottom: 8px;
}

.section {
  padding: 90px 6%;
}

.section h2 {
  font-size: 2.2rem;
  margin-bottom: 28px;
}

.alt {
  background: #131720;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

.card {
  background: #171b23;
  border: 1px solid #262b36;
  padding: 26px;
  border-radius: 18px;
}

.card h3 {
  margin-bottom: 10px;
  color: #00e676;
}

.tracker {
  max-width: 500px;
  background: #171b23;
  border: 1px solid #262b36;
  padding: 26px;
  border-radius: 18px;
}

.tracker label {
  display: block;
  margin: 14px 0 8px;
  font-weight: 700;
}

.tracker input,
.tracker select {
  width: 100%;
  padding: 14px;
  border: 1px solid #333;
  border-radius: 12px;
  background: #0f1115;
  color: #fff;
}

.tracker p {
  margin-top: 18px;
  font-weight: 700;
}

.footer {
  text-align: center;
  padding: 28px 20px;
  border-top: 1px solid #222;
  color: #cfcfcf;
}

@media (max-width: 900px) {
  .grid,
  .stats {
    grid-template-columns: 1fr;
  }

  .nav {
    display: none;
  }

  .menu-btn {
    display: block;
  }

  .mobile-menu.show {
    display: flex;
  }
}
function calculatePlan() {
  const weight = parseFloat(document.getElementById("weight").value);
  const goal = document.getElementById("goal").value;
  const result = document.getElementById("result");

  if (!weight || weight <= 0) {
    result.textContent = "Vul een geldig gewicht in.";
    return;
  }

  let calories = 0;

  if (goal === "bulk") {
    calories = weight * 36;
    result.textContent = `Jouw bulk calorie-inname: ongeveer ${Math.round(calories)} kcal per dag.`;
  } else if (goal === "cut") {
    calories = weight * 28;
    result.textContent = `Jouw cut calorie-inname: ongeveer ${Math.round(calories)} kcal per dag.`;
  } else {
    calories = weight * 32;
    result.textContent = `Jouw onderhoudscalorieën: ongeveer ${Math.round(calories)} kcal per dag.`;
  }
}

function toggleMenu() {
  document.getElementById("mobileMenu").classList.toggle("show");
}

function closeMenu() {
  document.getElementById("mobileMenu").classList.remove("show");
}
